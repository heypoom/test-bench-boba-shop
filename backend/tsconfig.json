{
  "compilerOptions": {
    "target":          "ES2022",
    "module":          "ESNext",
    "moduleResolution": "bundler",
    "lib":             ["ES2022"],
    "strict":          true,
    "skipLibCheck":    true,
    "noEmit":          true,
    "outDir":          "dist",
    "rootDir":         "src",
    "esModuleInterop": true
  },
  "include": ["src"]
}
